","link","label","HeaderMenu","opened","toggle","close","location","active","setActive","pathname","items","map","to","className","undefined","onClick","children","direction","align","bg","h","pl","pr","style","justifyContent","gap","size","fw","c","secondary","visibleFrom","hiddenFrom","onClose","padding","title","zIndex","mx","my"],"sources":["/Users/clairemerlin/Documents/site-vitrine/src/components/HeaderMenu.tsx"],"sourcesContent":["import React, { useEffect, useState } from 'react';\nimport { Burger, Divider, Drawer, Flex, Group, ScrollArea, Text } from '@mantine/core';\nimport { useDisclosure } from '@mantine/hooks';\nimport { Link, useLocation } from 'react-router-dom';\nimport { colors } from '../utils/colors';\nimport './HeaderMenu.css';\n\nconst links = [\n  { link: '/', label: 'Home' },\n  { link: '/portfolio', label: 'Portfolio' },\n  { link: '/about', label: 'About' },\n  { link: '/contact', label: 'Contact' },\n];\n\nexport function HeaderMenu() {\n  const [opened, { toggle, close }] = useDisclosure(false);\n  const location = useLocation();\n  const [active, setActive] = useState(location.pathname || links[0].link);\n\n  useEffect(() => {\n    setActive(location.pathname || links[0].link);\n  }, [location.pathname]);\n\n  const items = links.map((link) => (\n    <Link\n      key={link.label}\n      to={link.link}\n      className=\"link\"\n      data-active={active === link.link || undefined}\n      onClick={() => {\n        setActive(link.link);\n        close();\n      }}\n    >\n      {link.label}\n    </Link>\n  ));\n\n  return (\n    <Flex direction=\"row\" align=\"center\" bg=\"#DCDCDA\" h={40} pl={40} pr={40} style={{justifyContent: \"space-between\"}}>\n      <Flex direction=\"row\" align=\"center\" gap={20}>\n      <Text size=\"xl\" fw={800} c={colors.secondary}>{`</>`}</Text>\n      <Text size='lg'>Claire Merlin</Text>\n      </Flex>\n        <Group gap={8} visibleFrom=\"xs\">\n          {items}\n        </Group>\n\n        <Burger\n          opened={opened}\n          onClick={toggle}\n          hiddenFrom=\"xs\"\n          size=\"sm\"\n          aria-label=\"Toggle navigation\"\n        />\n\n      <Drawer\n        opened={opened}\n        onClose={close}\n        size=\"100%\"\n        padding=\"md\"\n        title=\"Navigation\"\n        hiddenFrom=\"xs\"\n        zIndex={1000000}\n      >\n        <ScrollArea h=\"calc(100vh - 80px)\" mx=\"-md\">\n          <Divider my=\"sm\" />\n          {items}\n        </ScrollArea>\n      </Drawer>\n    </Flex>\n  );\n}"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAClD,OAASC,MAAM,CAAEC,OAAO,CAAEC,MAAM,CAAEC,IAAI,CAAEC,KAAK,CAAEC,UAAU,CAAEC,IAAI,KAAQ,eAAe,CACtF,OAASC,aAAa,KAAQ,gBAAgB,CAC9C,OAASC,IAAI,CAAEC,WAAW,KAAQ,kBAAkB,CACpD,OAASC,MAAM,KAAQ,iBAAiB,CACxC,MAAO,kBAAkB,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAE1B,KAAM,CAAAC,KAAK,CAAG,CACZ,CAAEC,IAAI,CAAE,GAAG,CAAEC,KAAK,CAAE,MAAO,CAAC,CAC5B,CAAED,IAAI,CAAE,YAAY,CAAEC,KAAK,CAAE,WAAY,CAAC,CAC1C,CAAED,IAAI,CAAE,QAAQ,CAAEC,KAAK,CAAE,OAAQ,CAAC,CAClC,CAAED,IAAI,CAAE,UAAU,CAAEC,KAAK,CAAE,SAAU,CAAC,CACvC,CAED,MAAO,SAAS,CAAAC,UAAUA,CAAA,CAAG,CAC3B,KAAM,CAACC,MAAM,CAAE,CAAEC,MAAM,CAAEC,KAAM,CAAC,CAAC,CAAGd,aAAa,CAAC,KAAK,CAAC,CACxD,KAAM,CAAAe,QAAQ,CAAGb,WAAW,CAAC,CAAC,CAC9B,KAAM,CAACc,MAAM,CAAEC,SAAS,CAAC,CAAGzB,QAAQ,CAACuB,QAAQ,CAACG,QAAQ,EAAIV,KAAK,CAAC,CAAC,CAAC,CAACC,IAAI,CAAC,CAExElB,SAAS,CAAC,IAAM,CACd0B,SAAS,CAACF,QAAQ,CAACG,QAAQ,EAAIV,KAAK,CAAC,CAAC,CAAC,CAACC,IAAI,CAAC,CAC/C,CAAC,CAAE,CAACM,QAAQ,CAACG,QAAQ,CAAC,CAAC,CAEvB,KAAM,CAAAC,KAAK,CAAGX,KAAK,CAACY,GAAG,CAAEX,IAAI,eAC3BJ,IAAA,CAACJ,IAAI,EAEHoB,EAAE,CAAEZ,IAAI,CAACA,IAAK,CACda,SAAS,CAAC,MAAM,CAChB,cAAaN,MAAM,GAAKP,IAAI,CAACA,IAAI,EAAIc,SAAU,CAC/CC,OAAO,CAAEA,CAAA,GAAM,CACbP,SAAS,CAACR,IAAI,CAACA,IAAI,CAAC,CACpBK,KAAK,CAAC,CAAC,CACT,CAAE,CAAAW,QAAA,CAEDhB,IAAI,CAACC,KAAK,EATND,IAAI,CAACC,KAUN,CACP,CAAC,CAEF,mBACEH,KAAA,CAACX,IAAI,EAAC8B,SAAS,CAAC,KAAK,CAACC,KAAK,CAAC,QAAQ,CAACC,EAAE,CAAC,SAAS,CAACC,CAAC,CAAE,EAAG,CAACC,EAAE