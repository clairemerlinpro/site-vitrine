"\n        zIndex={1000000}\n      >\n        <ScrollArea h=\"calc(100vh - 80px)\" mx=\"-md\">\n          <Divider my=\"sm\" />\n          {items}\n        </ScrollArea>\n      </Drawer>\n    </header>\n  );\n}\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAC3C,OAASC,MAAM,CAAEC,SAAS,CAAEC,OAAO,CAAEC,MAAM,CAAEC,KAAK,CAAEC,UAAU,KAAQ,eAAe,CACrF,OAASC,aAAa,KAAQ,gBAAgB,CAC9C,OAASC,WAAW,KAAQ,wBAAwB,CACpD,OAASC,IAAI,CAAEC,WAAW,KAAQ,kBAAkB,CACpD,MAAO,CAAAC,OAAO,KAAM,2BAA2B,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEhD,KAAM,CAAAC,KAAK,CAAG,CACZ,CAAEC,IAAI,CAAE,QAAQ,CAAEC,KAAK,CAAE,UAAW,CAAC,CACrC,CAAED,IAAI,CAAE,UAAU,CAAEC,KAAK,CAAE,SAAU,CAAC,CACtC,CAAED,IAAI,CAAE,QAAQ,CAAEC,KAAK,CAAE,OAAQ,CAAC,CAClC,CAAED,IAAI,CAAE,YAAY,CAAEC,KAAK,CAAE,WAAY,CAAC,CAC3C,CAED,MAAO,SAAS,CAAAC,UAAUA,CAAA,CAAG,CAC3B,KAAM,CAACC,MAAM,CAAE,CAAEC,MAAM,CAAEC,KAAM,CAAC,CAAC,CAAGf,aAAa,CAAC,KAAK,CAAC,CACxD,KAAM,CAAAgB,QAAQ,CAAGb,WAAW,CAAC,CAAC,CAC9B,KAAM,CAACc,MAAM,CAAEC,SAAS,CAAC,CAAGzB,QAAQ,CAACuB,QAAQ,CAACG,QAAQ,EAAIV,KAAK,CAAC,CAAC,CAAC,CAACC,IAAI,CAAC,CAExElB,SAAS,CAAC,IAAM,CACd0B,SAAS,CAACF,QAAQ,CAACG,QAAQ,EAAIV,KAAK,CAAC,CAAC,CAAC,CAACC,IAAI,CAAC,CAC/C,CAAC,CAAE,CAACM,QAAQ,CAACG,QAAQ,CAAC,CAAC,CAEvB,KAAM,CAAAC,KAAK,CAAGX,KAAK,CAACY,GAAG,CAAEX,IAAI,eAC3BJ,IAAA,CAACJ,IAAI,EAEHoB,EAAE,CAAEZ,IAAI,CAACA,IAAK,CACda,SAAS,CAAEnB,OAAO,CAACM,IAAK,CACxB,cAAaO,MAAM,GAAKP,IAAI,CAACA,IAAI,EAAIc,SAAU,CAC/CC,OAAO,CAAEA,CAAA,GAAM,CACbP,SAAS,CAACR,IAAI,CAACA,IAAI,CAAC,CACpBK,KAAK,CAAC,CAAC,CACT,CAAE,CAAAW,QAAA,CAEDhB,IAAI,CAACC,KAAK,EATND,IAAI,CAACC,KAUN,CACP,CAAC,CAEF,mBACEH,KAAA,WAAQe,SAAS,CAAEnB,OAAO,CAACuB,MAAO,CAAAD,QAAA,eAChClB,KAAA,CAACb,SAAS,EAACiC,IAAI,CAAC,IAAI,CAACL,SAAS,CAAEnB,OAAO,CAACyB,KAAM,CAAAH,QAAA,eAC5CpB,IAAA,CAACL,WAAW,EAAC2B,IAAI,CAAE,EAAG,CAAE,CAAC,cACzBtB,IAAA,CAACR,KAAK,EAACgC,GAAG,CAAE,CAAE,CAACC,WAAW,CAAC,IAAI,CAAAL,QAAA,CAC5BN,KAAK,CACD,CAAC,cAERd,IAAA,CAACZ,MAAM,EACLmB,MAAM,CAAEA,MAAO,CACfY,OAAO,CAAEX,MAAO,CAChBkB,UAAU,CAAC,IAAI,CACfJ,IAAI,CAAC,IAAI,CACT,aAAW,mBAAmB,C